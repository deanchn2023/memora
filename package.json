{
  "name": "memora",
  "version": "2.1.0",
  "description": "忆境 Memora - AI驱动的个人记忆与事项管理助手",
  "main": "main.js",
  "author": "Dean Chen",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "build:dir": "electron-builder --mac --dir"
  },
  "dependencies": {
    "uuid": "^9.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.memora.app",
    "productName": "Memora",
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"],
      "icon": "build/icon.png"
    },
    "asar": true,
    "asarUnpack": [
      "scripts/**",
      "resources/**"
    ],
    "files": [
      "main.js",
      "preload.js",
      "src/**",
      "scripts/**",
      "prompts/**",
      "resources/**",
      "package.json",
      "!src/scripts/memory/memories.json",
      "!src/scripts/memory/entity-graph.json",
      "!src/scripts/notebook/notes.json"
    ]
  }
}